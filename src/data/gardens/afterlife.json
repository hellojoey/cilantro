          "contentType": "question",
          "text": "Do you believe some part of you continues after your body dies?",
          "vibe": "mortality",
          "difficulty": 3
        },
        {
          "id": "afterlife-seed-02",
          "contentType": "question",
          "text": "Do you live as if this life is the only one you get?",
          "vibe": "mortality",
          "difficulty": 3
        },
        {
          "id": "afterlife-seed-03",
          "contentType": "question",
          "text": "Would you want to know, for certain, what happens after death?",
          "vibe": "truth",
          "difficulty": 3
        },
        {
          "id": "afterlife-seed-04",
          "contentType": "question",
          "text": "Have you ever felt the presence of someone who's gone?",
          "vibe": "wonder",
          "difficulty": 3
        },
        {
          "id": "afterlife-seed-05",
          "contentType": "question",
          "text": "Does the idea of simply not existing frighten you?",
